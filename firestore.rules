rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each user can only access their own data
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Business codes — short shareable handles a boss sends to employees / customers.
    // Read: any signed-in user, including anonymous (quote.html public form).
    // Create: signed-in non-anon user only, and the new doc must record the
    //   creator's UID as ownerUID so subsequent writes can be gated.
    // Update / delete: only the original owner (matched against ownerUID).
    match /businessCodes/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous'
        && request.resource.data.ownerUID == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.ownerUID == request.auth.uid;
    }

    // Employee hours sync — cross-user access
    // Boss (ownerUID) can read; employee (employeeUID) can write their own data
    match /users/{ownerUID}/employeeHours/{employeeUID} {
      allow read: if request.auth.uid == ownerUID;
      allow write: if request.auth.uid == employeeUID;
    }
    match /users/{ownerUID}/employeeHours/{employeeUID}/{document=**} {
      allow read: if request.auth.uid == ownerUID;
      allow write: if request.auth.uid == employeeUID;
    }

    // Admin collection: only the verified admin email can read/write.
    // email_verified guards against providers that issue unverified email claims.
    match /admin/{document=**} {
      allow read, write: if request.auth != null
        && request.auth.token.email == 'smcnichol@outlook.com'
        && request.auth.token.email_verified == true;
    }

  }
}
