rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each user can only access their own data
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Business codes — any authenticated user can read (to look up by code)
    // Any authenticated user can write (employee looks themselves up, boss creates their code)
    match /businessCodes/{code} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Employee hours sync — cross-user access
    // Boss (ownerUID) can read; employee (employeeUID) can write their own data
    match /users/{ownerUID}/employeeHours/{employeeUID} {
      allow read: if request.auth.uid == ownerUID;
      allow write: if request.auth.uid == employeeUID;
    }
    match /users/{ownerUID}/employeeHours/{employeeUID}/{document=**} {
      allow read: if request.auth.uid == ownerUID;
      allow write: if request.auth.uid == employeeUID;
    }

    // Admin collection: only the admin email can read/write
    match /admin/{document=**} {
      allow read, write: if request.auth != null
        && request.auth.token.email == 'smcnichol@outlook.com';
    }

  }
}
